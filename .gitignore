# Exclude all.
*

# Except GitHub workflow

!.github/
!.github/**/
!.github/**/*.yaml

# Except core framework
!core/
!core/**/
!core/**/*.py

# Except CLI
!cli/
!cli/**/
!cli/**/*.py

# Except augmentations
!augmentations/
!augmentations/**/
!augmentations/**/*.py

# Except tests
!tests/
!tests/**/
!tests/**/*.py

# Except notebooks
!notebooks/
!notebooks/**/
!notebooks/**/*.ipynb

# Except configs
!configs/
!configs/**/
!configs/**/*.yaml

# Except scripts
!scripts/
!scripts/**/
!scripts/**/*

# Except project root files
!helper.sh
!Dockerfile
!docker-compose.yml
!pyproject.toml
!LICENSE
!README.md
!CONTRIBUTING.md
!.dockerignore
